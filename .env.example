# === КОНФИГУРАЦИЯ ПРИЛОЖЕНИЯ ===
# Копируйте этот файл в .env и заполните своими значениями
# Команда: cp .env.example .env

# Название приложения
REACT_APP_NAME="Салон «Здоровье и красота»"
REACT_APP_DOMAIN="bookme24.by"

# Горизонт планирования (в днях)
REACT_APP_BOOKING_HORIZON_DAYS=30

# Буфер между записями (в минутах)
REACT_APP_BUFFER_MINUTES=15

# Режим разработки (development / production)
REACT_APP_ENV=development

# === БУДУЩЕЕ: API Backend (когда подключим Node.js) ===
# REACT_APP_API_URL=https://api.bookme24.by
# REACT_APP_API_KEY=your_secret_key_here